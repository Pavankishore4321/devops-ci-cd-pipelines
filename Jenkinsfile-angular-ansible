// ─────────────────────────────────────────────────────────────────────────────
// Jenkins Pipeline: Angular Frontend — Build & Deploy via Ansible to Nginx
// Based on AspTax frontend deployment at Incresol Software Services
// Tools: Git, Node.js, Angular CLI (ng build), Ansible, Nginx
// ─────────────────────────────────────────────────────────────────────────────

pipeline {
    agent any

    environment {
        APP_NAME    = 'asptax-web'
        DEPLOY_ENV  = 'dev'               // Options: dev | prod
        ANSIBLE_DIR = '/etc/ansible'
        BUILD_DIR   = 'dist'
        NODE_HOME   = '/usr/local/bin'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                echo "Cleaning old build files from workspace..."
                sh '''
                    if [ -d "${WORKSPACE}/${APP_NAME}" ]; then
                        rm -rf ${WORKSPACE}/${APP_NAME}
                        echo "Workspace cleaned."
                    else
                        echo "Workspace already clean."
                    fi
                '''
            }
        }

        stage('Checkout Code') {
            steps {
                echo "Pulling latest Angular code from Git..."
                git branch: "${DEPLOY_ENV}",
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/your-org/asptax-web.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "Installing Angular project dependencies..."
                dir('asptax-web') {
                    sh '''
                        export TERM=xterm-256color
                        node --version
                        npm --version
                        ng version || npx ng version
                        npm install --force
                        echo "Dependencies installed."
                    '''
                }
            }
        }

        stage('Code Quality - SonarQube') {
            steps {
                echo "Running SonarQube scan on Angular source..."
                withSonarQubeEnv('SonarQube-Server') {
                    dir('asptax-web') {
                        sh '''
                            npx sonar-scanner \
                                -Dsonar.projectKey=${APP_NAME} \
                                -Dsonar.sources=src \
                                -Dsonar.exclusions=**/node_modules/**,**/dist/** \
                                -Dsonar.host.url=${SONAR_HOST_URL} \
                                -Dsonar.login=${SONAR_AUTH_TOKEN}
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                echo "Checking SonarQube Quality Gate result..."
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Angular App') {
            steps {
                echo "Building Angular app for ${DEPLOY_ENV} environment..."
                dir('asptax-web') {
                    sh '''
                        export TERM=xterm-256color

                        if [ "${DEPLOY_ENV}" = "prod" ]; then
                            npx ng build --configuration=production
                        else
                            npx ng build --configuration=${DEPLOY_ENV}
                        fi

                        echo "Angular build complete. Output files:"
                        ls -lh ${BUILD_DIR}/${APP_NAME}/
                    '''
                }
                // Note: Angular outputs to dist/<app-name>/ folder
                // This static build output is served by Nginx on the target server
            }
        }

        stage('Deploy via Ansible') {
            steps {
                echo "Deploying Angular dist/ to Nginx server via Ansible..."
                sh '''
                    ansible-playbook ${ANSIBLE_DIR}/deploy-angular-nginx.yml \
                        --extra-vars "env=${DEPLOY_ENV} app_name=${APP_NAME}" \
                        -v
                '''
                // Ansible playbook copies dist/<app-name>/ to Nginx web root
                // e.g. /var/www/html/ or /usr/share/nginx/html/
                // Then reloads Nginx: systemctl reload nginx
            }
        }

        stage('Health Check') {
            steps {
                echo "Verifying Angular app is live via Nginx..."
                sh '''
                    sleep 10
                    STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://your-server-ip)
                    if [ "$STATUS" -eq 200 ]; then
                        echo "Health check passed. Angular app is live on Nginx."
                    else
                        echo "Health check FAILED. HTTP Status: $STATUS"
                        exit 1
                    fi
                '''
            }
        }
    }

    post {
        success {
            echo "Angular app (${APP_NAME}) deployed to ${DEPLOY_ENV} successfully."
        }
        failure {
            echo "Pipeline FAILED. Check the stage logs above."
        }
        always {
            cleanWs()
        }
    }
}
